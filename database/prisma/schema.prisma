generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum MarketType {
  FOREX
  CRYPTO
  STOCK
  INDEX
  COMMODITY
}

enum AlertDirection {
  ABOVE
  BELOW
  CROSSING_UP
  CROSSING_DOWN
}

enum AlertStatus {
  ACTIVE
  TRIGGERED
  PAUSED
  CANCELLED
  EXPIRED
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRED
  CANCELLED
}

enum PreferredLanguage {
  FA
  EN
}

model User {
  id           String   @id @default(uuid())
  telegramId   String?  @unique
  username     String?
  firstName    String?
  lastName     String?
  languageCode       String?
  preferredLanguage PreferredLanguage?
  role               UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  alerts        Alert[]
  subscriptions Subscription[]

  @@index([telegramId])
  @@index([username])
}

model Market {
  id         String     @id @default(uuid())
  symbol     String     @unique
  name       String?
  type       MarketType
  baseAsset  String?
  quoteAsset String?
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  alerts Alert[]
  latestPrice MarketPrice?
  priceHistory MarketPriceHistory[]

  @@index([symbol])
  @@index([type])
}

model MarketPrice {
  id        String   @id @default(uuid())
  marketId  String   @unique
  price     Decimal
  source    String   @default("manual")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId])
  @@index([updatedAt])
}

model MarketPriceHistory {
  id         String   @id @default(uuid())
  marketId   String
  price      Decimal
  source     String   @default("manual")
  observedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId])
  @@index([marketId, observedAt])
  @@index([observedAt])
}

model Alert {
  id             String         @id @default(uuid())
  userId         String
  marketId       String
  title          String?
  targetPrice    Decimal
  direction      AlertDirection
  status         AlertStatus    @default(ACTIVE)
  triggeredAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([marketId])
  @@index([status])
  @@index([direction])
}

model Line {
  id        String   @id @default(uuid())
  userId    String?
  marketId  String?
  label     String?
  price     Decimal
  color     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([marketId])
}

model Subscription {
  id        String             @id @default(uuid())
  userId    String
  plan      String
  status    SubscriptionStatus @default(TRIAL)
  startsAt  DateTime           @default(now())
  endsAt    DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}
